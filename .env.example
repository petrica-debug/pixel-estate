# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/pixelestate

# Redis
REDIS_URL=redis://localhost:6379

# Blockchain
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_WS_URL=wss://polygon-bor-rpc.publicnode.com
CHAIN_ID=137
DEPLOYER_PRIVATE_KEY=         # DO NOT COMMIT — use secrets manager in prod

# Contract Addresses (filled after deployment)
PIXEL_ESTATE_CONTRACT=
RENTAL_DISTRIBUTOR_CONTRACT=
SALE_VOTING_CONTRACT=
MARKETPLACE_CONTRACT=
PROPERTY_REGISTRY_CONTRACT=
KYC_REGISTRY_CONTRACT=
USDC_CONTRACT=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# KYC Provider (Sumsub)
SUMSUB_API_URL=https://api.sumsub.com
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_WEBHOOK_SECRET=

# IPFS (Pinata)
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_GATEWAY_URL=

# WalletConnect
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_CHAIN_ID=137
NEXT_PUBLIC_PIXEL_ESTATE_CONTRACT=
NEXT_PUBLIC_RENTAL_DISTRIBUTOR_CONTRACT=
NEXT_PUBLIC_MARKETPLACE_CONTRACT=
NEXT_PUBLIC_USDC_CONTRACT=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359

# Fiat On-Ramp (Transak)
NEXT_PUBLIC_TRANSAK_API_KEY=
NEXT_PUBLIC_TRANSAK_ENV=STAGING

# Email (SendGrid or Resend)
SENDGRID_API_KEY=
